# =============================================================================
# Local Dify MCP memory boilerplate — workspace env
#
# Created by ./memory/bootstrap.sh on first install. Re-running bootstrap never
# overwrites this file, so user-supplied API keys survive `git pull` upgrades.
# Dataset IDs (DIFY_DATASET_<NAME>_ID) are normally written by
# ./memory/scripts/dify-setup.sh.
# =============================================================================

# ---------- Identity (auto-injected by bootstrap.sh) ----------
# These three placeholders are replaced by bootstrap.sh on first install.
# If you see the literal `__...__` strings here, bootstrap has not run yet.
COMPOSE_PROJECT_NAME=__COMPOSE_PROJECT_NAME__
MCP_CONTAINER_NAME=__MEMORY_SERVER_NAME__
MCP_IMAGE_NAME=__MCP_IMAGE_NAME__

# ---------- Host data location (optional override) ----------
# MEMORY_DATA_DIR=/absolute/path/to/.memory

# ---------- Dify version pinning ----------
# Resolved on first dify-bootstrap and pinned in memory/.dify-version.
# DIFY_VERSION=1.10.0

# ---------- Dify Knowledge API ----------
DIFY_API_URL=http://api:5001/v1
DIFY_KNOWLEDGE_API_KEY=

# Optional: scope `search_memory` to a specific subset of datasets.
# Leave empty to search every dataset bound below in DIFY_DATASETS.
DIFY_DATASET_IDS=

# Optional: raw JSON for Dify's /datasets/{id}/retrieve payload. Empty
# means use the retrieval settings configured in the Dify UI.
DIFY_RETRIEVAL_MODEL_JSON=

MCP_MEMORY_MAX_RESULTS=8
MCP_MEMORY_TIMEOUT_MS=20000

# ---------- Named dataset slots ----------
# Comma-separated list of slot names. Each slot has a corresponding
# DIFY_DATASET_<NAME>_ID variable below. Add as many as you want
# (e.g. add `decisions,runbooks` for extra families).
# `dify-setup.sh` reads this list to drive its bind/auto-create wizard.
DIFY_DATASETS=daily,knowledge,plans,investigations

DIFY_DATASET_DAILY_ID=
DIFY_DATASET_KNOWLEDGE_ID=
DIFY_DATASET_PLANS_ID=
DIFY_DATASET_INVESTIGATIONS_ID=

# Pipeline routing (slot names from DIFY_DATASETS).
DIFY_FLUSH_DATASET=daily              # flush.mjs writes daily-<ts>.md docs here
DIFY_COMPILE_DATASET=knowledge        # compile.mjs writes knowledge-<slug>-<ts>.md docs here
DIFY_ABSORB_DEFAULT_DATASET=knowledge # absorb_files default target

# Legacy: if set, used as fallback when no slot is resolvable.
DIFY_WRITE_DATASET_ID=

# Compile/absorb document indexing.
DIFY_SESSION_INDEXING_TECHNIQUE=high_quality
DIFY_SESSION_DOC_FORM=text_model
DIFY_SESSION_DOC_LANGUAGE=English
DIFY_SESSION_PROCESS_RULE_PRESET=conversation
DIFY_SESSION_PROCESS_RULE_JSON=

# ---------- Memory pipeline ----------
# LLM provider used by hooks/flush.mjs and scripts/compile.mjs.
#   claude: spawn `claude -p` (reuses Claude Code auth)
#   codex: spawn `codex exec --json`
#   anthropic: REST with ANTHROPIC_API_KEY (+ ANTHROPIC_MODEL)
#   openai: REST with OPENAI_API_KEY (+ OPENAI_MODEL)
MEMORY_LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
MEMORY_LLM_TIMEOUT_MS=120000

# How many top knowledge candidates compile considers per atom.
MEMORY_COMPILE_SEARCH_LIMIT=5

# ---------- Flush thresholds ----------
MEMORY_HOOK_MAX_TURNS=30
MEMORY_HOOK_MAX_CHARS=80000
MEMORY_HOOK_SESSION_END_MIN_TURNS=1
MEMORY_HOOK_PRECOMPACT_MIN_TURNS=5

# ---------- Absorb safety ----------
# Per-file size cap for absorb_files (bytes). Files above this are skipped.
ABSORB_MAX_FILE_BYTES=500000
