# =============================================================================
# Local Dify MCP memory boilerplate — workspace env
#
# Created by ./memory/bootstrap.sh on first install. Re-running bootstrap never
# overwrites this file, so user-supplied API keys survive `git pull` upgrades.
# =============================================================================

# ---------- Identity (auto-injected by bootstrap.sh) ----------
# Local orchestration identity. Keep unique per workspace.
COMPOSE_PROJECT_NAME=__COMPOSE_PROJECT_NAME__
MCP_CONTAINER_NAME=__MEMORY_SERVER_NAME__
MCP_IMAGE_NAME=__MCP_IMAGE_NAME__
# MEMORY_SLUG=<auto-injected by bootstrap.sh>

# ---------- Host data location (optional override) ----------
# Persistent Dify runtime data defaults to ../.memory via scripts/lib.sh.
# Override only if you intentionally want a different host data root.
# MEMORY_DATA_DIR=/absolute/path/to/.memory

# ---------- Dify version pinning ----------
# Resolved on first bootstrap and pinned in memory/.dify-version.
# Set this only when intentionally installing/upgrading to a specific Dify tag.
# DIFY_VERSION=1.10.0

# ---------- Dify Knowledge API ----------
# Internal Dify API URL on the Docker Compose network.
DIFY_API_URL=http://api:5001/v1

# Fill these after creating a Dify Knowledge API key and knowledge base(s).
DIFY_KNOWLEDGE_API_KEY=
DIFY_DATASET_IDS=

# Optional JSON object passed to Dify's /datasets/{id}/retrieve endpoint.
# Leave empty to use retrieval settings configured in the Dify UI.
DIFY_RETRIEVAL_MODEL_JSON=

# Compile/search behaviour.
MCP_MEMORY_MAX_RESULTS=8
MCP_MEMORY_TIMEOUT_MS=20000

# Knowledge base that receives compile-stage writes. If empty, the first ID
# in DIFY_DATASET_IDS is used.
DIFY_WRITE_DATASET_ID=
DIFY_SESSION_INDEXING_TECHNIQUE=high_quality
DIFY_SESSION_DOC_FORM=text_model
DIFY_SESSION_DOC_LANGUAGE=English

# Compile-created documents use this Dify chunking preset unless overridden.
#   conversation: custom chunks around section headings (good default)
#   automatic: Dify automatic chunking
#   none/inherit: omit process_rule, use knowledge base default
DIFY_SESSION_PROCESS_RULE_PRESET=conversation

# Advanced override. If set, this raw JSON is passed as Dify process_rule.
# Example:
# {"mode":"custom","rules":{"pre_processing_rules":[{"id":"remove_extra_spaces","enabled":true},{"id":"remove_urls_emails","enabled":false}],"segmentation":{"separator":"\n\n### ","max_tokens":700,"chunk_overlap":120}}}
DIFY_SESSION_PROCESS_RULE_JSON=

# ---------- Memory pipeline ----------
# Distillation provider used by hooks/flush.mjs and scripts/compile.mjs.
#   claude: spawn `claude -p` (reuses Claude Code auth, no API key needed)
#   codex: spawn `codex exec --json`
#   anthropic: direct REST with ANTHROPIC_API_KEY (set ANTHROPIC_MODEL too if non-default)
#   openai: direct REST with OPENAI_API_KEY (set OPENAI_MODEL too if non-default)
MEMORY_LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Per-call timeout for the LLM (flush + compile).
MEMORY_LLM_TIMEOUT_MS=120000

# How many top candidates compile.mjs fetches from Dify per atom.
MEMORY_COMPILE_SEARCH_LIMIT=5

# ---------- Flush thresholds ----------
# How many transcript turns the flush hook hands to the LLM extractor.
MEMORY_HOOK_MAX_TURNS=30
MEMORY_HOOK_MAX_CHARS=80000
# Skip flush events with fewer than this many turns.
MEMORY_HOOK_SESSION_END_MIN_TURNS=1
MEMORY_HOOK_PRECOMPACT_MIN_TURNS=5
