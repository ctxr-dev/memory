# =============================================================================
# Local Dify MCP memory boilerplate — workspace env
#
# Created by ./memory/bootstrap.sh on first install. Re-running bootstrap never
# overwrites this file, so user-supplied API keys survive `git pull` upgrades.
# Dataset IDs (DIFY_DATASET_<NAME>_ID) are normally written by
# ./memory/scripts/dify-setup.sh.
# =============================================================================

# ---------- Identity (auto-injected by bootstrap.sh) ----------
# These three placeholders are replaced by bootstrap.sh on first install.
# If you see the literal `__...__` strings here, bootstrap has not run yet.
COMPOSE_PROJECT_NAME=__COMPOSE_PROJECT_NAME__
MCP_CONTAINER_NAME=__MEMORY_SERVER_NAME__
MCP_IMAGE_NAME=__MCP_IMAGE_NAME__

# ---------- Host data location (optional override) ----------
# MEMORY_DATA_DIR=/absolute/path/to/.memory

# ---------- Bridge container internals (do not normally set) ----------
# Mount point inside the bridge container that the host workspace is
# bind-mounted to. Hard-coded in compose.mcp.yaml; only override if you
# also change the compose bind. The MCP `scan_documents` and
# `absorb_files` tools resolve workspace paths against this value.
# WORKSPACE_MOUNT=/workspace

# ---------- Dify version pinning ----------
# Resolved on first dify-bootstrap and pinned in memory/.dify-version.
# DIFY_VERSION=1.10.0

# ---------- Dify Knowledge API ----------
DIFY_API_URL=http://api:5001/v1
DIFY_KNOWLEDGE_API_KEY=

# Optional: scope `search_memory` to a specific subset of datasets.
# Leave empty to search every dataset slot bound below.
DIFY_DATASET_IDS=

# Optional: raw JSON for Dify's /datasets/{id}/retrieve payload. Empty
# means use the retrieval settings configured in the Dify UI.
DIFY_RETRIEVAL_MODEL_JSON=

MCP_MEMORY_MAX_RESULTS=8
MCP_MEMORY_TIMEOUT_MS=20000

# ---------- Named dataset slots ----------
# Each line declares one slot. The slot NAME comes from the env-var name:
# DIFY_DATASET_<NAME>_ID -> <name lowercased> (so SELF_IMPROVEMENT becomes
# the slot `self_improvement`). Leave the value empty for slots you have
# not bound yet — `dify-setup.sh` will offer to bind/auto-create them.
# Comment a line out to drop the slot entirely.
#
# Add your own slots by adding a new line. No second list to maintain.
DIFY_DATASET_DAILY_ID=
DIFY_DATASET_KNOWLEDGE_ID=
DIFY_DATASET_PLANS_ID=
DIFY_DATASET_INVESTIGATIONS_ID=
DIFY_DATASET_SELF_IMPROVEMENT_ID=
# DIFY_DATASET_RUNBOOKS_ID=
# DIFY_DATASET_DECISIONS_ID=

# Pipeline routing — slot NAMES that must resolve via the lines above.
DIFY_FLUSH_DATASET=daily              # flush.mjs writes daily-<ts>.md docs here
DIFY_COMPILE_DATASET=knowledge        # compile.mjs writes knowledge-<slug>-<ts>.md docs here
DIFY_ABSORB_DEFAULT_DATASET=knowledge # absorb_files default target

# Legacy: if set, used as fallback when no slot is resolvable.
DIFY_WRITE_DATASET_ID=

# Compile/absorb document indexing.
DIFY_SESSION_INDEXING_TECHNIQUE=high_quality
DIFY_SESSION_DOC_FORM=text_model
DIFY_SESSION_DOC_LANGUAGE=English
DIFY_SESSION_PROCESS_RULE_PRESET=conversation
DIFY_SESSION_PROCESS_RULE_JSON=

# ---------- Memory pipeline ----------
# LLM provider used by hooks/flush.mjs and scripts/compile.mjs.
#   claude: spawn `claude -p` (reuses Claude Code auth)
#   codex: spawn `codex exec --json`
#   anthropic: REST with ANTHROPIC_API_KEY (+ ANTHROPIC_MODEL)
#   openai: REST with OPENAI_API_KEY (+ OPENAI_MODEL)
MEMORY_LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
MEMORY_LLM_TIMEOUT_MS=120000

# How many top knowledge candidates compile considers per atom.
MEMORY_COMPILE_SEARCH_LIMIT=5

# Bounded retry: after this many failed compile attempts on the same daily
# doc, give up and disable it to prevent duplicate-create loops.
MEMORY_COMPILE_METADATA_RETRY_LIMIT=3

# Stale-lock timeout for compile.mjs (ms). If two SessionStarts spawn
# detached compiles concurrently, the second one finds an active lock and
# exits cleanly. If the lock owner is dead OR the lock is older than this
# threshold, the lock is reclaimed. Default: 30 minutes — long enough to
# cover real LLM-bound runs across several daily docs, short enough to
# auto-recover from a truly stuck owner.
MEMORY_COMPILE_LOCK_STALE_MS=1800000

# ---------- Embedding model (REQUIRED for hybrid_search on Dify 1.14+) ----------
# Dify 1.14+ requires `embedding_provider_name` + `embedding_model_name`
# inside `retrieval_model.weights.vector_setting` for any hybrid_search
# call. Without these, every dataset create AND every retrieve fails
# with a pydantic "Field required" error. Pass BOTH or neither.
#
# IMPORTANT: the provider value is Dify's full plugin URI, not the bare
# provider name. Examples (uncomment ONE pair):
#
#   OpenAI (recommended for cloud, best cost/quality, $0.02/M tokens):
# DIFY_EMBEDDING_MODEL=text-embedding-3-small
# DIFY_EMBEDDING_MODEL_PROVIDER=langgenius/openai/openai
#
#   OpenAI (best quality, $0.13/M tokens):
# DIFY_EMBEDDING_MODEL=text-embedding-3-large
# DIFY_EMBEDDING_MODEL_PROVIDER=langgenius/openai/openai
#
#   Cohere:
# DIFY_EMBEDDING_MODEL=embed-english-v3.0
# DIFY_EMBEDDING_MODEL_PROVIDER=langgenius/cohere/cohere
#
#   Local via Ollama (zero ongoing cost; bge-m3 is the strongest local choice):
# DIFY_EMBEDDING_MODEL=bge-m3
# DIFY_EMBEDDING_MODEL_PROVIDER=langgenius/ollama/ollama
#
# These values must ALSO be configured in the Dify UI as the System
# Default Embedding Model (Settings -> Model Provider -> select provider,
# install plugin, paste API key, then System Model Settings -> set as
# default Embedding Model). Otherwise Dify rejects with "No embedding
# model available". `dify-setup.sh` pre-flights this check.

# ---------- Flush thresholds ----------
MEMORY_HOOK_MAX_TURNS=30
MEMORY_HOOK_MAX_CHARS=80000
MEMORY_HOOK_SESSION_END_MIN_TURNS=1
MEMORY_HOOK_PRECOMPACT_MIN_TURNS=5

# ---------- Absorb safety ----------
# Per-file size cap for absorb_files (bytes). Files above this are skipped.
ABSORB_MAX_FILE_BYTES=500000
